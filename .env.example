# OrderCloud MCP Server Configuration

# Base API URL (sandbox or production)
ORDERCLOUD_BASE_URL=https://sandboxapi.ordercloud.io

# Client Credentials auth (recommended)
ORDERCLOUD_CLIENT_ID=your-client-id
ORDERCLOUD_CLIENT_SECRET=your-client-secret
ORDERCLOUD_AUTH_URL=https://auth.ordercloud.io/oauth/token
ORDERCLOUD_SCOPE=FullAccess

# OR: Pre-provided token (optional, takes precedence if set)
# ORDERCLOUD_ACCESS_TOKEN=your-access-token
